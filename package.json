{
	"name": "mor-diem-sdk",
	"version": "0.2.0",
	"description": "SDK and CLI for the Morpheus AI network",
	"type": "module",
	"main": "release/index.js",
	"bin": {
		"mor-diem": "./release/cli/mor-diem.js"
	},
	"files": [
		"release/",
		"docs/",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"dev": "bun run src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target node",
		"build:cli": "bun build src/cli/mor-diem.ts --outdir dist/cli --target node",
		"release": "bun run build && bun run build:cli && rm -rf release && cp -r dist release",
		"cli": "source .env 2>/dev/null; bun run src/cli/mor-diem.ts",
		"chat": "source .env 2>/dev/null; bun run src/cli/mor-diem.ts chat",
		"setup": "source .env 2>/dev/null; bun run scripts/setup-morpheus-node.ts",
		"proxy": "source .env 2>/dev/null; bun run src/proxy/openai-session-proxy.ts",
		"test": "bun test",
		"test:models": "source .env 2>/dev/null; bun run scripts/test-models.ts",
		"model-status": "cd docs/model-status && python3 -m http.server 8000",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"@scure/bip32": "^1.6.2",
		"@scure/bip39": "^1.5.4",
		"viem": "^2.23.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/bun": "^1.1.14",
		"@types/node": "^25.3.1",
		"typescript": "^5.7.2"
	},
	"engines": {
		"bun": ">=1.0.0"
	},
	"keywords": [
		"morpheus",
		"mor",
		"diem",
		"inference",
		"ai",
		"decentralized",
		"blockchain",
		"base"
	],
	"license": "UNLICENSED",
	"author": "@robertjchristian"
}
