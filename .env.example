# MOR DIEM SDK Configuration
# Copy to .env and fill in your values

# =============================================================================
# WALLET (Required for staking/P2P mode)
# =============================================================================
# Your wallet mnemonic (12 or 24 words) - KEEP THIS SECRET
MOR_MNEMONIC="your twelve word seed phrase goes here"

# Wallet derivation index (default: 0)
# MOR_WALLET_INDEX=0

# =============================================================================
# MORPHEUS NODE (Local P2P setup)
# =============================================================================
# HTTP API port (not the TCP port 9081!)
MORPHEUS_ROUTER_URL=http://localhost:8082

# Cookie path - where Morpheus Node creates auth cookie (must be absolute)
# MORPHEUS_COOKIE_PATH=/absolute/path/to/bin/morpheus/.cookie

# Proxy port
MORPHEUS_PROXY_PORT=8083

# =============================================================================
# RPC (Optional - for better reliability)
# =============================================================================
# Get a free key from https://alchemy.com
# ALCHEMY_API_KEY=your-alchemy-api-key

# Or use any Base RPC
# MOR_RPC_URL=https://mainnet.base.org

# =============================================================================
# ALTERNATIVE: Gateway Mode (no local node needed)
# =============================================================================
# Get your API key from https://api.mor.org
# MOR_API_KEY=sk-xxxxx
